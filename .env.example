# AI Interview Desk - OpenRouter Configuration
# Get your key at https://openrouter.ai/keys
# The key is used server-side only.

OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Change the model here (default is cheap & capable)
# Examples: anthropic/claude-3.5-haiku-20241022, anthropic/claude-3-7-sonnet-20250219, openai/gpt-4o-mini, google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=anthropic/claude-3.5-haiku